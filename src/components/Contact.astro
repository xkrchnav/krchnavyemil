---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;
---

<section id="contact" class="py-24 bg-zinc-950 relative overflow-hidden">
  <!-- Green accent line top -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[#39FF14] via-[#FF0000] to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4">

    <!-- Section header -->
    <div class="flex items-center gap-4 mb-6">
      <h2 class="text-white font-bold italic uppercase text-4xl md:text-5xl tracking-tight" style="font-family: 'Oswald', sans-serif;">
        {t.contact.title}
      </h2>
      <div class="h-px flex-1 bg-zinc-700"></div>
    </div>
    <p class="text-zinc-400 mb-14 max-w-xl">{t.contact.subtitle}</p>

    <div class="grid md:grid-cols-2 gap-12">

      <!-- Contact Form -->
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="space-y-5"
      >
        <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
        <input type="hidden" name="subject" value="Emil Krchňavý #87 – Website Contact" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

        <div>
          <label for="contact-name" class="text-zinc-300 text-sm uppercase tracking-widest font-bold block mb-2" style="font-family: 'Oswald', sans-serif;">{t.contact.form_name}</label>
          <input
            id="contact-name"
            type="text"
            name="name"
            required
            class="w-full bg-zinc-900 border border-zinc-700 text-white text-base px-4 py-3 focus:outline-none focus:border-[#39FF14] transition-colors placeholder-zinc-600"
            style="font-family: 'Oswald', sans-serif;"
            placeholder={t.contact.form_name}
          />
        </div>

        <div>
          <label for="contact-email" class="text-zinc-300 text-sm uppercase tracking-widest font-bold block mb-2" style="font-family: 'Oswald', sans-serif;">{t.contact.form_email}</label>
          <input
            id="contact-email"
            type="email"
            name="email"
            required
            class="w-full bg-zinc-900 border border-zinc-700 text-white text-base px-4 py-3 focus:outline-none focus:border-[#39FF14] transition-colors placeholder-zinc-600"
            style="font-family: 'Oswald', sans-serif;"
            placeholder={t.contact.form_email}
          />
        </div>

        <div>
          <label for="contact-message" class="text-zinc-300 text-sm uppercase tracking-widest font-bold block mb-2" style="font-family: 'Oswald', sans-serif;">{t.contact.form_message}</label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            class="w-full bg-zinc-900 border border-zinc-700 text-white text-base px-4 py-3 focus:outline-none focus:border-[#39FF14] transition-colors placeholder-zinc-600 resize-none"
            style="font-family: 'Oswald', sans-serif;"
            placeholder={t.contact.form_message}
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-[#39FF14] text-zinc-950 font-bold uppercase tracking-widest text-base py-4 hover:bg-[#39FF14]/80 active:scale-95 transition-all"
          style="font-family: 'Oswald', sans-serif;"
        >
          {t.contact.form_submit} →
        </button>
      </form>

      <!-- Socials -->
      <div class="flex flex-col justify-center">
        <p class="text-zinc-400 text-xs uppercase tracking-widest font-semibold mb-8">{t.contact.socials_title}</p>

        <div class="space-y-4">
          <!-- Facebook -->
          <a
            href={t.contact.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-5 border border-zinc-700 hover:border-[#39FF14] p-5 group transition-all"
          >
            <div class="w-10 h-10 flex items-center justify-center bg-zinc-800 group-hover:bg-[#39FF14]/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="text-zinc-300 group-hover:text-[#39FF14] transition-colors" viewBox="0 0 24 24">
                <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
              </svg>
            </div>
            <div>
              <span class="text-white font-bold uppercase tracking-widest text-sm block">Facebook</span>
              <span class="text-zinc-500 text-xs">@emil.krchnavy</span>
            </div>
          </a>

          <!-- Instagram -->
          <a
            href={t.contact.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-5 border border-zinc-700 hover:border-[#39FF14] p-5 group transition-all"
          >
            <div class="w-10 h-10 flex items-center justify-center bg-zinc-800 group-hover:bg-[#39FF14]/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="text-zinc-300 group-hover:text-[#39FF14] transition-colors" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            </div>
            <div>
              <span class="text-white font-bold uppercase tracking-widest text-sm block">Instagram</span>
              <span class="text-zinc-500 text-xs">@emilkrchnavy</span>
            </div>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
